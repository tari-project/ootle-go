# Native libs are committed per platform under internal/cffi/lib/<goos>_<goarch>/
# (release + stripped, regenerated by scripts/build_native.sh). The per-platform libs in
# subdirs ARE tracked; ignore only stray ad-hoc builds dropped at the lib root.
/internal/cffi/lib/*.a
/internal/cffi/lib/*.dylib
/internal/cffi/lib/*.so

# Go build / test artifacts
*.test
*.out

# Editor / OS noise
/temp
.DS_Store
